#include"loader.h"
#include<stdio.h>
#include<stdlib.h>


Network *load_network(const char *path){
   FILE *file = fopen(path ,"rb");
   if (file == NULL){
      perror("Error opening \"model.bin\"");
      return NULL ;
      } 
   Layer   *fc1 = malloc(sizeof(Layer));
   fc1->weights = make_tensor(128,784);
   fc1->bias    = make_tensor(128,1);

   Layer   *fc2 = malloc(sizeof(Layer));
   fc2->weights = make_tensor(10,128);
   fc2->bias    = make_tensor(10,1);

   if(fread(fc1 , sizeof(fc1) ,1 , file )==0){
      perror ("Error reading file for fc1 ");
      return NULL ;
      }
   
